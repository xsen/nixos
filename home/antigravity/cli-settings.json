{
  "allowNonWorkspaceAccess": true,
  "enableTelemetry": false,
  "notifications": true,
  "editor": "zed --wait",
  "permissions": {
    "allow": [
      "command(cd)",
      "command(php artisan test)",
      "command(composer)",
      "command(cat)",
      "command(find)",
      "command(grep)",
      "command(rg)",
      "command(ls)",
      "command(git)",
      "command(jq)",
      "command(head)",
      "command(tail)",
      "command(file)"
