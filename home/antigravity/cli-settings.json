  "runningLightSpeed": "fast",
  "showFeedbackSurvey": false,
  "statusLine": {
    "type": "command",
    "command": "/home/evgeny/.gemini/antigravity-cli/statusline-command.sh",
    "enabled": true
  },
  "trustedWorkspaces": [
    "/home/evgeny/Code/Soft/eve-zavod",
    "/home/evgeny/Code/nixos/xsen"
  ]
}
